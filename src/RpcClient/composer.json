{
    "name": "php-websocket-rpc/rpc-client",
    "description": "Async RPC client over WebSocket using amphp and msgpack",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Prasetyo Wicaksono",
            "email": "pras@tuta.io"
        }
    ],
    "keywords": ["rpc", "websocket", "amphp", "async", "msgpack", "client", "proxy"],
    "homepage": "https://github.com/php-websocket-rpc/rpc-client",
    "support": {
        "issues": "https://github.com/php-websocket-rpc/php-websocket-rpc/issues"
    },
    "require": {
        "php": ">=8.5",
        "ext-msgpack": "*",
        "amphp/amp": "^3",
        "amphp/websocket-client": "^2",
        "friendsofphp/proxy-manager-lts": "^1.0",
        "php-websocket-rpc/rpc": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "PhpWebsocketRpc\\RpcClient\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpWebsocketRpc\\RpcClient\\Tests\\": "Tests/"
        }
    }
}
