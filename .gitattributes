# Auto-detect text files
* text=auto

# Export settings for monorepo split
/.gitattributes export-ignore
/.gitignore export-ignore
/.github export-ignore
/examples export-ignore
/scripts export-ignore
/phpunit.xml export-ignore
/vitest.config.ts export-ignore
/package.json export-ignore
/composer.json export-ignore

# PHP split packages — keep tests, keep examples
src/Rpc/Tests export-ignore
src/RpcClient/Tests export-ignore
src/RpcServer/Tests export-ignore

# TS split packages — keep tests
src/TypescriptRpcClient/src/*.test.ts export-ignore
src/TypescriptCodegen/src/*.test.ts export-ignore
